{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "spicy-chicken-preview",
  "version": "0.1.0",
  "identifier": "com.laoyutong.spicy-chicken-preview",
  "build": {
    "beforeDevCommand": "pnpm run vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Spicy Chicken Preview",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
