{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "spicy-chicken-preview",
  "version": "0.1.0",
  "identifier": "com.laoyutong.spicy-chicken-preview",
  "build": {
    "beforeDevCommand": "pnpm run vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Spicy Chicken Preview",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": ["jpg", "jpeg", "png", "gif", "webp", "bmp", "svg", "avif", "tiff", "tif", "heic", "heif"],
        "name": "Image",
        "description": "Picture File",
        "role": "Viewer",
        "mimeType": "image/*"
      }
    ]
  }
}
